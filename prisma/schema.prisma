generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@index([email])
}
model Note {
  id Int @id @default(autoincrement())
}
model Task {
  id Int @id @default(autoincrement())
}